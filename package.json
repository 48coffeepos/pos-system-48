{
	"name": "48-coffee-pos",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"post-cta-init": "npx -y create-db@latest --user-agent tanstack/tsrouter",
		"db:generate": "dotenv -e .env.local -- prisma generate",
		"db:push": "dotenv -e .env.local -- prisma db push",
		"db:pull": "dotenv -e .env.local -- prisma db pull",
		"db:migrate": "dotenv -e .env.local -- prisma migrate dev",
		"db:studio": "dotenv -e .env.local -- prisma studio",
		"db:seed": "dotenv -e .env.local -- prisma db seed",
		"auth:generate": "npx auth@latest generate --config ./src/integrations/better-auth/auth.ts"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@better-auth/prisma-adapter": "^1.6.11",
		"@faker-js/faker": "^10.3.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@phosphor-icons/react": "^2.1.10",
		"@prisma/adapter-neon": "^7.8.0",
		"@prisma/client": "^7.4.2",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/match-sorter-utils": "latest",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-form": "^1.32.0",
		"@tanstack/react-form-devtools": "^0.2.27",
		"@tanstack/react-query": "latest",
		"@tanstack/react-query-devtools": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/react-table": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"better-auth": "^1.5.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.545.0",
		"next-themes": "^0.4.6",
		"prisma": "^7.4.2",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"shadcn": "^4.7.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
