generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id       Int       @id @default(autoincrement())
  name     String
  accounts Account[]
}

model Account {
  id         Int      @id @default(autoincrement())
  role_id    Int
  role       Role     @relation(fields: [role_id], references: [id])
  username   String   @unique
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Menu {
  id             Int         @id @default(autoincrement())
  name           String
  price          Float
  category       String
  temperatures   String[]
  hot_cup_sizes  Int[]
  iced_cup_sizes Int[]
  hot_12oz_price   Float       @default(0)
  iced_12oz_price  Float       @default(0)
  iced_16oz_price  Float       @default(0)
  order_items    OrderItem[]
}

model Order {
  order_id         String      @id
  method           String
  reference_number String?
  paid             Float?
  change           Float?
  total            Float
  created_at       DateTime    @default(now())
  order_items      OrderItem[]
}

model OrderItem {
  id            Int         @id @default(autoincrement())
  order_id      String
  order         Order       @relation(fields: [order_id], references: [order_id])
  menu_id       Int
  menu          Menu        @relation(fields: [menu_id], references: [id])
  name          String
  discount      String?
  quantity      Int
  loyalty       Boolean?
  discount_name String?
  discount_id   String?
  subtotal      Float
  total         Float
  change        Float?
  note          String?
  cup_type      String?
  cup_size      String?
  addon_items   AddonItem[]
}

model Addon {
  id          Int         @id @default(autoincrement())
  name        String
  price       Float
  addon_items AddonItem[]
}

model AddonItem {
  id            Int      @id @default(autoincrement())
  addon_id      Int
  addon         Addon    @relation(fields: [addon_id], references: [id])
  order_item_id Int
  order_item    OrderItem @relation(fields: [order_item_id], references: [id])
  quantity      Int
}

model inventory {
  inventory_id    String @id @default(uuid())
  name            String
  stock           Int
  yesterday_stock Int?
  type            Inventory_Type
}

enum Inventory_Type {
  CUP
  STANDALONE
}

