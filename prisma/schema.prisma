generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id
  name            String
  email           String    @unique
  emailVerified   Boolean   @default(false)
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  banReason       String?
  banned          Boolean?  @default(false)
  displayUsername String?
  role            String?
  username        String?   @unique
  banExpires      DateTime?
  accounts        Account[]
  expenses        Expense[]
  orders          Order[]
  sessions        Session[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Addon {
  addon_id    String           @id @default(uuid())
  name        String           @unique
  price       Decimal          @db.Decimal(10, 2)
  addon_items OrderItemAddon[]

  @@map("addons")
}

model Expense {
  expense_id  String       @id @default(uuid())
  staff_id    String
  type        Expense_Type
  description String
  amount      Decimal      @db.Decimal(10, 2)
  timestamp   DateTime     @default(now())
  staff       User         @relation(fields: [staff_id], references: [id])

  @@map("expenses")
}

model Inventory {
  inventory_id    String          @id @default(uuid())
  name            String          @unique
  stock           Int             @default(0)
  yesterday_stock Int?
  type            Inventory_Type
  menu_items      MenuInventory[]

  @@map("inventory")
}

model Menu {
  menu_id         String          @id @default(uuid())
  name            String          @unique
  price           Decimal?        @db.Decimal(10, 2)
  type            Inventory_Type?
  inventory_items MenuInventory[]
  order_items     OrderItem[]

  @@map("menu")
}

model MenuInventory {
  menu_inv_id  String    @id @default(uuid())
  menu_id      String
  inventory_id String
  price        Decimal   @db.Decimal(10, 2)
  inventory    Inventory @relation(fields: [inventory_id], references: [inventory_id])
  menu         Menu      @relation(fields: [menu_id], references: [menu_id], onDelete: Cascade)

  @@unique([menu_id, inventory_id])
  @@map("menu_inventory")
}

model OrderItemAddon {
  order_item_addon_id  String    @id @default(uuid())
  addon_id             String
  order_item_id        String
  addon_name_snapshot  String
  addon_price_snapshot Decimal   @db.Decimal(10, 2)
  quantity             Int
  total_price          Decimal   @db.Decimal(10, 2)
  addon                Addon     @relation(fields: [addon_id], references: [addon_id])
  order_item           OrderItem @relation(fields: [order_item_id], references: [order_item_id], onDelete: Cascade)

  @@map("order_item_addons")
}

model OrderItem {
  order_item_id      String           @id @default(uuid())
  order_id           String
  menu_id            String?
  snapshot_menu_name String
  snapshot_price     Decimal          @db.Decimal(10, 2)
  snapshot_inventory String
  unit_price         Decimal          @db.Decimal(10, 2)
  quantity           Int              @default(1)
  line_total         Decimal          @db.Decimal(10, 2)
  loyalty            Boolean          @default(false)
  discount_amount    Decimal          @default(5) @db.Decimal(10, 2)
  discount_type      Discount_Type?
  discount_id_number String?
  discount_contact   String?
  addon_items        OrderItemAddon[]
  menu               Menu?            @relation(fields: [menu_id], references: [menu_id])
  order              Order            @relation(fields: [order_id], references: [order_id], onDelete: Cascade)

  @@map("order_items")
}

model Order {
  order_id         String         @id @default(uuid())
  staff_id         String
  grand_total      Decimal        @db.Decimal(10, 2)
  method           Payment_Method
  reference_number String?
  amount_tendered  Decimal?       @db.Decimal(10, 2)
  change_amount    Decimal?       @db.Decimal(10, 2)
  note             String?
  created_at       DateTime       @default(now())
  order_items      OrderItem[]
  staff            User           @relation(fields: [staff_id], references: [id])

  @@map("orders")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Inventory_Type {
  CUP
  STANDALONE
}

enum Inventory_Status {
  AVAILABLE
  UNAVAILABLE
}

enum Expense_Type {
  CASH_IN
  CASH_OUT
}

enum Payment_Method {
  CASH
  GCASH
  GRAB
}

enum Discount_Type {
  PWD
  SENIOR
}
